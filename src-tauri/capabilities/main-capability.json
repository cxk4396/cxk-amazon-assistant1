{
  "identifier": "main-capability",
  "description": "Main capability for CXK Amazon Assistant",
  "local": true,
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select"
  ]
}
